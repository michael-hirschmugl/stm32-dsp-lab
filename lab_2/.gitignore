# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
/build/
/build_*/
/Debug/
/Release/
/out/
/bin/
/obj/

# Toolchain/linker outputs
*.o
*.a
*.d
*.su
*.lst
*.map
*.elf
*.hex
*.bin

# Optional: CubeIDE / SW4STM32 / Eclipse artifacts
/.settings/
/.project
/.cproject
/.mxproject
*.launch
*.jlink
*.stlink

# -----------------------------------------------------------------------------
# Python / plotting scripts
# -----------------------------------------------------------------------------
/python/.venv/
/python/venv/
/python/__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.pdb

# Local data dumps / captures
/python/*.log
/python/*.csv
/python/*.npy
/python/*.npz
/python/*.dat
/python/*.bin
/python/*.raw

# -----------------------------------------------------------------------------
# OS junk
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Editor / IDE junk
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.bak

# -----------------------------------------------------------------------------
# Generated docs / temporary files
# -----------------------------------------------------------------------------
*.tmp
*.temp

# -----------------------------------------------------------------------------
# Optional: Keep the build folder out, but allow a placeholder file if you want
# -----------------------------------------------------------------------------
# !/build/.gitkeep